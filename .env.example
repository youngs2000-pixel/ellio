# ===== 세계 3차 전쟁 v2.0 — 환경변수 예시 =====
# 이 파일을 복사해서 ".env" 로 만들고 실제 키를 넣으세요.
# 주의: 진짜 .env 파일은 .gitignore 에 의해 GitHub 에 올라가지 않습니다.
#       Vercel 에서는 이 값을 "프로젝트 설정 > Environment Variables" 에 넣습니다.

# Google Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=여기에_실제_키를_붙여넣으세요

# (선택) 사용할 모델. 비워두면 gemini-2.0-flash 사용.
#   추천: gemini-2.0-flash (빠르고 저렴), gemini-2.5-flash (더 똑똑)
GEMINI_MODEL=gemini-2.0-flash

# ===== 온라인 공유 랭킹 (선택) =====
# Upstash Redis 정보. 없으면 게임은 자동으로 "이 기기" 로컬 랭킹을 씁니다.
# Vercel → Storage 에서 Upstash Redis(또는 KV)를 만들어 프로젝트에 연결하면
# 보통 아래 변수가 자동으로 채워집니다(둘 중 어떤 이름이든 인식).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 또는 Upstash 콘솔에서 직접:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel의 Upstash Integration이 접두어를 붙여 자동 생성하는 이름도 인식합니다:
#   UPSTASH_REDIS_REST_KV_REST_API_URL / UPSTASH_REDIS_REST_KV_REST_API_TOKEN
#   (REST API용 URL/TOKEN만 사용 — redis:// 형태인 _KV_URL/_REDIS_URL 은 안 씀)
